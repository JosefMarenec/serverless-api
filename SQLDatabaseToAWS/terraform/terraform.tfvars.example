# Copy this to terraform.tfvars and fill in your values
# terraform.tfvars is git-ignored

project     = "ecom-api"
environment = "dev"
aws_region  = "us-east-1"

rds_host        = "your-rds-instance.xxxxxxxxxx.us-east-1.rds.amazonaws.com"
rds_port        = 5432
db_name         = "ecommerce"
rds_secret_name = "ecom-api-dev-rds-credentials"

vpc_subnet_ids         = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
vpc_security_group_ids = ["sg-xxxxxxxx"]

lambda_memory_mb = 256
lambda_timeout_s = 30
log_level        = "INFO"
